<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#F5F6F8">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<title>Money</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='114' fill='%2316181D'/%3E%3Crect x='150' y='150' width='66' height='212' rx='33' fill='%231E9E6B'/%3E%3Crect x='296' y='262' width='66' height='100' rx='33' fill='%23E5484D'/%3E%3C/svg%3E">
<style>
  :root{
    --bg:#F5F6F8; --surface:#FFFFFF; --ink:#16181D; --muted:#787E8A;
    --line:#ECEEF2; --line-2:#E3E6EC;
    --out:#E5484D; --out-soft:#FDEDED;
    --in:#1E9E6B; --in-soft:#E7F6EF; --warn:#E0920C;
    --radius:18px; --shadow:0 1px 2px rgba(16,18,29,.04), 0 8px 24px rgba(16,18,29,.05);
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0;padding:0;}
  body{
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,system-ui,sans-serif;
    background:var(--bg); color:var(--ink);
    font-size:15px; line-height:1.45;
    -webkit-font-smoothing:antialiased;
    font-variant-numeric:tabular-nums; font-feature-settings:"tnum";
    overscroll-behavior-y:none;
  }
  .num{font-variant-numeric:tabular-nums; font-feature-settings:"tnum";}
  button{font-family:inherit; cursor:pointer; border:none; background:none; color:inherit;}
  button:focus-visible,[tabindex]:focus-visible{outline:2.5px solid var(--ink); outline-offset:2px; border-radius:6px;}
  .touch{touch-action:manipulation;}

  /* ---------- Dashboard ---------- */
  #app{max-width:520px; margin:0 auto; min-height:100vh;}
  .screen{padding:18px 18px 132px;}
  .topbar{display:flex; align-items:center; justify-content:space-between; margin-bottom:18px;}
  .month{display:flex; align-items:center; gap:6px; text-align:left;}
  .month-txt{font-size:15px; font-weight:700; letter-spacing:-0.01em;}
  .month small{display:block; font-size:11px; font-weight:600; letter-spacing:.09em; text-transform:uppercase; color:var(--muted); margin-bottom:1px;}
  .month .month-chev{width:18px; height:18px; stroke:var(--muted); stroke-width:2.2; fill:none; flex:0 0 auto;}
  .month:active{opacity:.55;}
  .iconbtn{width:42px; height:42px; border-radius:12px; display:grid; place-items:center; background:var(--surface); box-shadow:var(--shadow);}
  .iconbtn svg{width:20px; height:20px; stroke:var(--ink); stroke-width:1.8; fill:none;}

  .card{background:var(--surface); border-radius:var(--radius); box-shadow:var(--shadow); padding:18px;}
  .stats{display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--line); border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow); margin-bottom:12px;}
  .stat{background:var(--surface); padding:16px 18px;}
  .stat .lbl{font-size:11px; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); display:flex; align-items:center; gap:6px;}
  .stat .lbl .dot{width:7px; height:7px; border-radius:50%;}
  .stat.exp .dot{background:var(--out);} .stat.inc .dot{background:var(--in);}
  .stat .fig{font-size:27px; font-weight:750; letter-spacing:-0.02em; margin-top:7px; line-height:1;}
  .stat.exp .fig{color:var(--out);} .stat.inc .fig{color:var(--in);}
  .stat .sub{font-size:12px; color:var(--muted); margin-top:6px;}

  .daily{margin-bottom:12px; padding:16px 18px;}
  .daily-top{display:flex; align-items:baseline; justify-content:space-between; gap:10px;}
  .daily .lbl{font-size:11px; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:var(--muted);}
  .daily .left{font-size:21px; font-weight:750; letter-spacing:-0.01em; color:var(--in); white-space:nowrap;}
  .daily .bar{height:9px; border-radius:99px; background:var(--line); overflow:hidden; margin:12px 0 8px;}
  .daily .fill{height:100%; border-radius:99px; background:var(--in); transition:width .3s ease, background .25s; min-width:2px;}
  .daily .daily-sub{font-size:12.5px; color:var(--muted);}
  .daily.warn .left{color:var(--warn);} .daily.warn .fill{background:var(--warn);}
  .daily.over .left{color:var(--out);} .daily.over .fill{background:var(--out);}
  .setnote{font-size:12px; color:var(--muted); padding:0 16px 11px; margin-top:-3px; line-height:1.4;}

  .payday{display:flex; align-items:center; gap:14px; margin-bottom:22px;}
  .payday .big{font-size:30px; font-weight:750; letter-spacing:-0.02em; line-height:1;}
  .payday .meta{font-size:12.5px; color:var(--muted);}
  .payday .meta b{color:var(--ink); font-weight:650;}
  .cal{width:46px; height:46px; border-radius:13px; background:var(--ink); color:#fff; display:grid; place-items:center; flex:0 0 auto;}
  .cal svg{width:22px; height:22px; stroke:#fff; stroke-width:1.7; fill:none;}

  .sectionhead{display:flex; align-items:center; justify-content:space-between; margin:0 4px 10px;}
  .sectionhead h2{font-size:12px; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin:0;}
  .linkbtn{font-size:13px; font-weight:600; color:var(--muted); padding:4px 6px; border-radius:8px;}
  .linkbtn:active{background:var(--line);}

  .bills{padding:6px 6px 8px;}
  .bill{display:flex; align-items:center; gap:13px; padding:11px 12px; border-radius:13px;}
  .bill:active{background:var(--bg);}
  .check{width:23px; height:23px; border-radius:7px; border:2px solid var(--line-2); flex:0 0 auto; display:grid; place-items:center; transition:all .12s;}
  .bill.paid .check{background:var(--in); border-color:var(--in);}
  .check svg{width:13px; height:13px; stroke:#fff; stroke-width:3; fill:none; opacity:0; transition:opacity .12s;}
  .bill.paid .check svg{opacity:1;}
  .bill .nm{flex:1; font-weight:550; font-size:14.5px;}
  .bill.paid .nm{color:var(--muted); text-decoration:line-through;}
  .bill .amt{font-weight:600; font-size:14.5px;}
  .bill.paid .amt{color:var(--muted);}
  .billsfoot{display:flex; justify-content:space-between; align-items:flex-end; padding:14px 14px 6px; margin-top:4px; border-top:1px solid var(--line);}
  .bf-lbl{font-size:11px; font-weight:600; letter-spacing:.07em; text-transform:uppercase; color:var(--muted); margin-bottom:4px;}
  .bf-total .bf-val{font-size:17px; font-weight:700; letter-spacing:-0.01em; color:var(--ink); line-height:1;}
  .bf-left{text-align:right;}
  .bf-left .bf-big{font-size:27px; font-weight:780; letter-spacing:-0.02em; color:var(--ink); line-height:1;}
  .bf-left.done .bf-big{color:var(--in);}
  .bills-collapsed{display:flex; align-items:center; gap:12px; padding:9px 8px;}
  .allpaid{display:flex; align-items:center; gap:7px; margin-left:auto; color:var(--in); font-size:22px; font-weight:760; letter-spacing:-0.01em;}
  .allpaid svg{width:21px; height:21px; stroke:var(--in); stroke-width:2.7; fill:none;}
  .bills-collapsed .chev{width:18px; height:18px; stroke:var(--muted); stroke-width:2; fill:none; flex:0 0 auto;}

  .empty{padding:22px 16px; text-align:center; color:var(--muted); font-size:13.5px;}
  .empty button{color:var(--ink); font-weight:600; text-decoration:underline; text-underline-offset:2px;}

  .recent{margin-top:22px;}
  .tx{display:flex; align-items:center; gap:13px; padding:12px 14px; background:var(--surface); border-radius:14px; box-shadow:var(--shadow); margin-bottom:8px; cursor:pointer; transition:background .1s;}
  .tx:active{background:var(--bg);}
  .tx .tag{width:9px; height:9px; border-radius:50%; flex:0 0 auto;}
  .tx.exp .tag{background:var(--out);} .tx.inc .tag{background:var(--in);}
  .tx .info{flex:1; min-width:0;}
  .tx .info .c{font-weight:600; font-size:14.5px;}
  .tx .info .d{font-size:12px; color:var(--muted);}
  .tx .v{font-weight:700; font-size:15px;}
  .tx.exp .v{color:var(--out);} .tx.inc .v{color:var(--in);}
  .tx .del{width:30px; height:30px; border-radius:9px; display:grid; place-items:center; color:var(--muted); flex:0 0 auto;}
  .tx .del:active{background:var(--bg);}
  .tx .del svg{width:16px; height:16px; stroke:currentColor; stroke-width:1.8; fill:none;}

  /* ---------- Bottom action bar ---------- */
  .actionbar{position:fixed; left:0; right:0; bottom:0; z-index:40;
    max-width:520px; margin:0 auto; display:flex; gap:11px;
    padding:12px 18px calc(12px + env(safe-area-inset-bottom));
    background:linear-gradient(to top, var(--bg) 62%, rgba(245,246,248,0));}
  .act{flex:1; height:60px; border-radius:17px; font-size:16.5px; font-weight:700; letter-spacing:-0.01em;
    display:flex; align-items:center; justify-content:center; gap:9px; color:#fff; box-shadow:0 6px 16px rgba(16,18,29,.12); transition:transform .08s;}
  .act:active{transform:scale(.975);}
  .act svg{width:20px; height:20px; stroke:#fff; stroke-width:2.4; fill:none;}
  .act.exp{background:var(--out);} .act.inc{background:var(--in);}

  /* ---------- Sheets ---------- */
  .sheet{position:fixed; inset:0; z-index:60; background:var(--bg); display:flex; flex-direction:column;
    max-width:520px; margin:0 auto; transform:translateY(100%); transition:transform .26s cubic-bezier(.32,.72,.3,1); visibility:hidden;}
  .sheet.open{transform:translateY(0); visibility:visible;}
  #entry{z-index:70;}
  #month{overflow-y:auto;}
  #month .screen{padding:6px 18px calc(28px + env(safe-area-inset-bottom));}
  .msum{margin-bottom:20px;}
  .msum .mnet{font-size:34px; font-weight:780; letter-spacing:-0.02em; line-height:1; margin-top:6px;}
  .msum .mnet.pos{color:var(--in);} .msum .mnet.neg{color:var(--out);}
  .msum-sub{display:flex; gap:18px; margin-top:13px; font-size:13px; color:var(--muted); font-weight:600; flex-wrap:wrap;}
  .msum-sub i.d{display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:6px; vertical-align:middle;}
  .msum-sub i.in{background:var(--in);} .msum-sub i.out{background:var(--out);}
  .msec{margin-bottom:24px;}
  .msec .bf-lbl{padding:0 4px 9px;}
  .stackbar{display:flex; width:100%; height:18px; border-radius:9px; overflow:hidden; background:var(--line);}
  .stackbar .seg{height:100%;}
  .stackbar .seg + .seg{box-shadow:inset 1.5px 0 0 var(--surface);}
  .legend{margin-top:15px;}
  .leg{display:flex; align-items:center; gap:10px; padding:7px 0;}
  .leg .sw{width:11px; height:11px; border-radius:3px; flex:0 0 auto;}
  .leg .ln{flex:1; font-weight:600; font-size:14px;}
  .leg .lv{font-size:13px; color:var(--muted); font-weight:600; white-space:nowrap;}
  .stacktotal{display:flex; justify-content:space-between; align-items:baseline; margin-top:8px; padding:12px 0 10px; border-top:1px solid var(--line); font-size:13px; font-weight:600; color:var(--muted);}
  .stacktotal .num{font-size:16px; font-weight:750; color:var(--ink);}
  @media (prefers-reduced-motion:reduce){.sheet{transition:none;}}
  .sheethead{display:flex; align-items:center; justify-content:space-between; padding:16px 18px 6px;}
  .sheethead .title{font-size:13px; font-weight:700; letter-spacing:.06em; text-transform:uppercase;}
  .sheet.expense .sheethead .title{color:var(--out);}
  .sheet.income .sheethead .title{color:var(--in);}
  .closebtn{width:40px; height:40px; border-radius:11px; display:grid; place-items:center; background:var(--surface); box-shadow:var(--shadow);}
  .closebtn svg{width:18px; height:18px; stroke:var(--ink); stroke-width:2; fill:none;}
  .closebtn.del svg{stroke:var(--out); width:19px; height:19px;}

  /* entry amount */
  .amount{flex:0 0 auto; text-align:center; padding:14px 16px 6px; font-size:54px; white-space:nowrap; overflow:hidden;}
  .amount .cur{font-size:.37em; font-weight:600; color:var(--muted); vertical-align:.55em; margin-right:.05em;}
  .amount .val{font-size:1em; font-weight:760; letter-spacing:-0.03em; line-height:1;}
  .amount .val.zero{color:#C2C7D0;}

  .chips{display:flex; flex-wrap:wrap; gap:8px; padding:14px 16px 6px; justify-content:center; align-content:flex-start; overflow-y:auto;}
  .chip{padding:9px 15px; border-radius:999px; background:var(--surface); box-shadow:var(--shadow);
    font-size:14px; font-weight:600; color:var(--ink); border:2px solid transparent; transition:all .12s;}
  .chip.sel{color:#fff;}
  .sheet.expense .chip.sel{background:var(--out); border-color:var(--out);}
  .sheet.income .chip.sel{background:var(--in); border-color:var(--in);}
  .chip.add{color:var(--muted); border:2px dashed var(--line-2); background:transparent; box-shadow:none;}

  /* numpad */
  .pad{display:grid; grid-template-columns:repeat(3,1fr); gap:9px; padding:10px 16px 6px; margin-top:auto;}
  .key{height:62px; border-radius:15px; background:var(--surface); box-shadow:var(--shadow);
    font-size:25px; font-weight:600; display:grid; place-items:center; transition:transform .07s, background .1s;}
  .key:active{transform:scale(.94); background:var(--line);}
  .key.bsp svg{width:25px; height:25px; stroke:var(--ink); stroke-width:1.8; fill:none;}
  .savebtn{height:60px; margin:12px 16px calc(14px + env(safe-area-inset-bottom)); border-radius:17px; color:#fff;
    font-size:17px; font-weight:700; display:flex; align-items:center; justify-content:center; gap:9px; transition:opacity .15s, transform .08s;}
  .savebtn:active{transform:scale(.985);}
  .savebtn:disabled{opacity:.4;}
  .savebtn svg{width:20px; height:20px; stroke:#fff; stroke-width:2.4; fill:none;}
  .sheet.expense .savebtn{background:var(--out);}
  .sheet.income .savebtn{background:var(--in);}

  /* ---------- Settings ---------- */
  #settings{overflow-y:auto;}
  #settings .screen{padding:0 18px calc(28px + env(safe-area-inset-bottom));}
  .setgroup{background:var(--surface); border-radius:var(--radius); box-shadow:var(--shadow); margin-bottom:18px; overflow:hidden;}
  .setgroup h3{font-size:11px; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin:0; padding:15px 16px 9px;}
  .setrow{display:flex; align-items:center; gap:12px; padding:13px 16px; border-top:1px solid var(--line);}
  .setrow label{flex:1; font-weight:550; font-size:14.5px;}
  .setrow input[type=number],.setrow input[type=text]{
    width:104px; text-align:right; font:inherit; font-weight:600; padding:9px 11px; border-radius:10px;
    border:1.5px solid var(--line-2); background:var(--bg); color:var(--ink);}
  .setrow input:focus{outline:none; border-color:var(--ink);}
  .listrow{display:flex; align-items:center; gap:10px; padding:11px 16px; border-top:1px solid var(--line);}
  .listrow .nm{flex:1; font-weight:550; font-size:14.5px;}
  .listrow .nm input{width:100%; font:inherit; font-weight:550; border:none; background:none; color:inherit; padding:4px 0;}
  .listrow .nm input:focus{outline:none;}
  .listrow .amt input{width:96px; text-align:right; font:inherit; font-weight:600; padding:8px 10px; border-radius:9px; border:1.5px solid var(--line-2); background:var(--bg); color:var(--ink);}
  .listrow .amt input:focus{outline:none; border-color:var(--ink);}
  .listrow .rm{width:30px; height:30px; border-radius:8px; display:grid; place-items:center; color:var(--out); flex:0 0 auto;}
  .listrow .rm:active{background:var(--out-soft);}
  .listrow .rm svg{width:17px; height:17px; stroke:currentColor; stroke-width:1.9; fill:none;}
  .addrow{padding:12px 16px; border-top:1px solid var(--line); color:var(--ink); font-weight:600; font-size:14px; display:flex; align-items:center; gap:8px;}
  .addrow:active{background:var(--bg);}
  .addrow svg{width:17px; height:17px; stroke:currentColor; stroke-width:2.2; fill:none;}
  .btnrow{display:flex; gap:10px; margin-top:4px;}
  .ghost{flex:1; padding:14px; border-radius:13px; background:var(--surface); box-shadow:var(--shadow); font-weight:650; font-size:14px;}
  .ghost.danger{color:var(--out);}
  .ghost:active{background:var(--line);}

  /* ---------- Toast ---------- */
  #toast{position:fixed; left:50%; bottom:96px; transform:translate(-50%,16px); z-index:90;
    background:var(--ink); color:#fff; padding:11px 18px; border-radius:13px; font-size:14px; font-weight:600;
    box-shadow:0 8px 24px rgba(0,0,0,.22); opacity:0; pointer-events:none; transition:all .22s; max-width:90%;}
  #toast.show{opacity:1; transform:translate(-50%,0);}
  #toast.has-action{pointer-events:auto; display:flex; align-items:center; gap:14px; padding-right:8px;}
  #toast .undo{color:#fff; font-weight:750; padding:6px 12px; border-radius:9px; background:rgba(255,255,255,.16); font-size:14px;}
  #toast .undo:active{background:rgba(255,255,255,.3);}

  /* ---------- Entry: date + note ---------- */
  .entry-meta{display:flex; gap:9px; padding:4px 16px 2px; align-items:center;}
  .entry-meta input{font:inherit; font-weight:600; border:1.5px solid var(--line-2); background:var(--surface); color:var(--ink); border-radius:11px; padding:11px 12px;}
  .entry-meta input:focus{outline:none; border-color:var(--ink);}
  #entryDate{flex:0 0 auto; width:148px; text-align:left;}
  #entryNote{flex:1; min-width:0;}
  #entryNote::placeholder{color:var(--muted); font-weight:500;}

  /* ---------- Month navigation ---------- */
  .mnav{display:flex; align-items:center; gap:4px; justify-content:center; flex:1;}
  .mnav .navbtn{width:34px; height:34px; border-radius:10px; display:grid; place-items:center; background:var(--surface); box-shadow:var(--shadow);}
  .mnav .navbtn svg{width:17px; height:17px; stroke:var(--ink); stroke-width:2.2; fill:none;}
  .mnav .navbtn:active{background:var(--line);}
  .mnav .navbtn[disabled]{opacity:.32; box-shadow:none; pointer-events:none;}
  .mnav .title{min-width:128px; text-align:center;}

  /* ---------- Month: comparison + day groups + search ---------- */
  .mcompare{display:flex; gap:6px; margin-top:11px; font-size:12.5px; font-weight:650;}
  .mcompare .pill{padding:3px 9px; border-radius:99px; background:var(--bg); color:var(--muted);}
  .mcompare .pill.up{background:var(--out-soft); color:var(--out);}
  .mcompare .pill.down{background:var(--in-soft); color:var(--in);}
  .msearch{display:flex; align-items:center; gap:9px; background:var(--surface); box-shadow:var(--shadow); border-radius:12px; padding:0 12px; margin-bottom:10px;}
  .msearch svg{width:17px; height:17px; stroke:var(--muted); stroke-width:2; fill:none; flex:0 0 auto;}
  .msearch input{flex:1; font:inherit; border:none; background:none; color:var(--ink); padding:11px 0;}
  .msearch input:focus{outline:none;}
  .dayhdr{display:flex; align-items:baseline; justify-content:space-between; padding:14px 6px 6px; font-size:11px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--muted);}
  .dayhdr .dsum{font-weight:650; letter-spacing:0; text-transform:none; color:var(--muted);}
  .showmore{width:100%; padding:13px; margin-top:8px; border-radius:13px; background:var(--surface); box-shadow:var(--shadow); font-weight:650; font-size:14px; color:var(--ink);}
  .showmore:active{background:var(--line);}

  /* ---------- Onboarding ---------- */
  #onboard{z-index:80;}
  #onboard .ob-wrap{flex:1; overflow-y:auto; padding:8px 22px calc(20px + env(safe-area-inset-bottom));}
  #onboard .ob-logo{width:58px; height:58px; border-radius:16px; background:var(--ink); display:grid; place-items:center; margin:14px 0 16px;}
  #onboard .ob-logo svg{width:30px; height:30px;}
  #onboard h1{font-size:26px; font-weight:780; letter-spacing:-0.02em; margin:0 0 6px;}
  #onboard .ob-lede{color:var(--muted); font-size:15px; margin:0 0 22px; line-height:1.5;}
  #onboard .ob-field{margin-bottom:16px;}
  #onboard .ob-field label{display:block; font-size:13px; font-weight:650; margin-bottom:7px;}
  #onboard .ob-field .hint{color:var(--muted); font-weight:500; font-size:12px; margin-top:5px;}
  #onboard .ob-field input{width:100%; font:inherit; font-weight:600; padding:13px 14px; border-radius:13px; border:1.5px solid var(--line-2); background:var(--surface); color:var(--ink);}
  #onboard .ob-field input:focus{outline:none; border-color:var(--ink);}
  #onboard .ob-foot{padding:12px 22px calc(16px + env(safe-area-inset-bottom)); display:flex; flex-direction:column; gap:10px;}
  #onboard .ob-start{height:58px; border-radius:16px; background:var(--in); color:#fff; font-size:17px; font-weight:750; display:flex; align-items:center; justify-content:center;}
  #onboard .ob-start:active{transform:scale(.985);}
  #onboard .ob-skip{background:none; color:var(--muted); font-weight:600; font-size:14px; padding:6px; align-self:center;}
</style>
</head>
<body>

<div id="app">
  <!-- DASHBOARD -->
  <div id="dashboard" class="screen">
    <div class="topbar">
      <button class="month touch" id="dateBtn" aria-label="View this month so far">
        <span class="month-txt"><small id="dowLbl">Monday</small><span id="dateLbl">June 15, 2026</span></span>
        <svg class="month-chev" viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg>
      </button>
      <button class="iconbtn touch" id="openSettings" aria-label="Settings">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>
    </div>

    <div class="stats">
      <div class="stat exp">
        <div class="lbl"><span class="dot"></span>Spent</div>
        <div class="fig num" id="expFig">S$0</div>
      </div>
      <div class="stat inc">
        <div class="lbl"><span class="dot"></span>Income</div>
        <div class="fig num" id="incFig">S$0</div>
      </div>
    </div>

    <div class="card daily" id="dailyCard"></div>

    <div class="card payday" id="paydayCard">
      <div class="cal">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="3"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      </div>
      <div>
        <div class="big num" id="paydayBig">— days</div>
        <div class="meta" id="paydayMeta">till payday</div>
      </div>
    </div>

    <div class="sectionhead"><h2>Monthly bills</h2><button class="linkbtn touch" id="editBills">Edit</button></div>
    <div class="card bills" id="billsCard"></div>

    <div class="recent" id="recentWrap" hidden>
      <div class="sectionhead"><h2>Recent</h2></div>
      <div id="recentList"></div>
    </div>
  </div>

  <!-- ACTION BAR -->
  <div class="actionbar">
    <button class="act inc touch" id="addIncome">
      <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg> Income
    </button>
    <button class="act exp touch" id="addExpense">
      <svg viewBox="0 0 24 24"><path d="M5 12h14"/></svg> Expense
    </button>
  </div>
</div>

<!-- ENTRY SHEET -->
<div class="sheet" id="entry">
  <div class="sheethead">
    <button class="closebtn touch" id="entryClose" aria-label="Close"><svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
    <span class="title" id="entryTitle">Expense</span>
    <button class="closebtn del touch" id="entryDelete" aria-label="Delete this entry" style="display:none"><svg viewBox="0 0 24 24"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg></button>
  </div>
  <div class="amount" id="amountBox"><span class="cur" id="entryCur">S$</span><span class="val zero" id="entryVal">0</span></div>
  <div class="chips" id="entryChips"></div>
  <div class="entry-meta">
    <input type="date" id="entryDate" aria-label="Date">
    <input type="text" id="entryNote" placeholder="Add a note (optional)" maxlength="60" aria-label="Note">
  </div>
  <div class="pad">
    <button class="key touch" data-k="1">1</button><button class="key touch" data-k="2">2</button><button class="key touch" data-k="3">3</button>
    <button class="key touch" data-k="4">4</button><button class="key touch" data-k="5">5</button><button class="key touch" data-k="6">6</button>
    <button class="key touch" data-k="7">7</button><button class="key touch" data-k="8">8</button><button class="key touch" data-k="9">9</button>
    <button class="key touch" data-k=".">.</button><button class="key touch" data-k="0">0</button>
    <button class="key bsp touch" data-k="bsp" aria-label="Delete"><svg viewBox="0 0 24 24"><path d="M21 5H8L2 12l6 7h13a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1z"/><path d="M17 9l-5 5M12 9l5 5"/></svg></button>
  </div>
  <button class="savebtn touch" id="entrySave" disabled>Save</button>
</div>

<!-- SETTINGS SHEET -->
<div class="sheet" id="settings">
  <div class="sheethead">
    <button class="closebtn touch" id="settingsClose" aria-label="Close"><svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
    <span class="title" style="color:var(--ink)">Settings</span>
    <div style="width:40px"></div>
  </div>
  <div class="screen">
    <div class="setgroup">
      <h3>General</h3>
      <div class="setrow"><label for="setPayday">Payday (day of month)</label><input type="number" id="setPayday" min="1" max="31" inputmode="numeric"></div>
      <div class="setrow"><label for="setDailyInput">Daily spending budget</label><input type="number" id="setDailyInput" min="0" inputmode="decimal"></div>
      <div class="setrow"><label for="setMonthlyInput">Monthly spending budget</label><input type="number" id="setMonthlyInput" min="0" inputmode="decimal"></div>
      <div class="setrow"><label for="setCur">Currency symbol</label><input type="text" id="setCur" maxlength="4"></div>
      <div class="setrow"><label for="setLocale">Number format</label><select id="setLocale" style="width:148px; text-align:right; font:inherit; font-weight:600; padding:9px 11px; border-radius:10px; border:1.5px solid var(--line-2); background:var(--bg); color:var(--ink);">
        <option value="en-US">1,234.56</option>
        <option value="de-DE">1.234,56</option>
        <option value="fr-FR">1 234,56</option>
        <option value="en-IN">1,23,456.78</option>
      </select></div>
    </div>
    <div class="setgroup" id="billsGroup"><h3>Monthly bills</h3></div>
    <div class="setgroup" id="catGroup"><h3>Expense categories</h3></div>
    <div class="setgroup" id="srcGroup"><h3>Income sources</h3></div>
    <div class="btnrow">
      <button class="ghost touch" id="exportBtn">Back up data</button>
      <button class="ghost touch" id="importBtn">Restore</button>
    </div>
    <div class="btnrow"><button class="ghost danger touch" id="clearBtn">Erase all data</button></div>
    <input type="file" id="importFile" accept="application/json" hidden>
  </div>
</div>

<!-- MONTH DASHBOARD SHEET -->
<div class="sheet" id="month">
  <div class="sheethead">
    <button class="closebtn touch" id="monthClose" aria-label="Close"><svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
    <div class="mnav">
      <button class="navbtn touch" id="monthPrev" aria-label="Previous month"><svg viewBox="0 0 24 24"><path d="M15 6l-6 6 6 6"/></svg></button>
      <span class="title" id="monthTitle" style="color:var(--ink)">June 2026</span>
      <button class="navbtn touch" id="monthNext" aria-label="Next month"><svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg></button>
    </div>
    <div style="width:40px"></div>
  </div>
  <div class="screen" id="monthBody"></div>
</div>

<!-- ONBOARDING SHEET -->
<div class="sheet" id="onboard">
  <div class="ob-wrap">
    <div class="ob-logo">
      <svg viewBox="0 0 512 512"><rect x="150" y="150" width="66" height="212" rx="33" fill="#1E9E6B"/><rect x="296" y="262" width="66" height="100" rx="33" fill="#E5484D"/></svg>
    </div>
    <h1>Let's set up Money</h1>
    <p class="ob-lede">Three quick things and you're tracking. You can change any of these later in Settings.</p>
    <div class="ob-field">
      <label for="obCur">Currency symbol</label>
      <input type="text" id="obCur" maxlength="4" value="S$">
    </div>
    <div class="ob-field">
      <label for="obPayday">Payday — day of the month</label>
      <input type="number" id="obPayday" min="1" max="31" inputmode="numeric" value="25">
      <div class="hint">Drives the "days till payday" countdown.</div>
    </div>
    <div class="ob-field">
      <label for="obDaily">Daily spending budget</label>
      <input type="number" id="obDaily" min="0" inputmode="decimal" placeholder="e.g. 30">
      <div class="hint">Optional — a soft cap for everyday discretionary spending.</div>
    </div>
  </div>
  <div class="ob-foot">
    <button class="ob-start touch" id="obStart">Start tracking</button>
    <button class="ob-skip touch" id="obSkip">Skip for now</button>
  </div>
</div>

<div id="toast"></div>

<script>
"use strict";

/* ---------- Storage ----------
   On a phone (Capacitor) data is written to native device storage via the Preferences
   plugin, so it survives WebView/cache clears. In a plain browser it falls back to
   localStorage. `mem` is the synchronous source of truth, hydrated once before init(). */
var KEY = "money_app_v1";
var mem = null;
var Prefs = null, Fs = null, ShareP = null;
function getPlugin(n){ return (window.Capacitor && window.Capacitor.Plugins && window.Capacitor.Plugins[n]) || null; }
function readRaw(){ return mem; }
function writeRaw(v){
  mem = v;
  if(Prefs){ Prefs.set({ key:KEY, value:v }).catch(function(){}); }
  else { try { window.localStorage.setItem(KEY, v); } catch(e){} }
}

/* ---------- Default state ---------- */
function defaults(){
  return {
    currency: "S$",
    locale: "en-US",
    paydayDay: 25,
    dailyBudget: 0,
    monthlyBudget: 0,
    onboarded: false,
    categories: ["Food","Transport","Groceries","Shopping","Coffee","Bills"],
    sources: ["Salary","Freelance","Other"],
    bills: [
      {id:id(), name:"Rent", amount:0, paid:false},
      {id:id(), name:"Phone", amount:0, paid:false}
    ],
    billsMonth: monthKey(),
    tx: []
  };
}
function id(){ return Math.random().toString(36).slice(2,10); }
function monthKey(d){ d = d||new Date(); return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0"); }

var state;
var billsExpanded = false;
function applyDefaults(s){
  var d = defaults();
  for(var k in d){ if(s[k]===undefined) s[k] = d[k]; }
  return s;
}
function load(){
  var raw = readRaw();
  if(raw){
    try { state = JSON.parse(raw); } catch(e){ state = defaults(); }
  } else {
    state = defaults();
  }
  // backfill any missing fields
  applyDefaults(state);
  // auto-reset bill checkboxes when a new month starts
  if(state.billsMonth !== monthKey()){
    state.bills.forEach(function(b){ b.paid = false; });
    state.billsMonth = monthKey();
  }
  save();
}
function save(){ writeRaw(JSON.stringify(state)); }

/* ---------- Helpers ---------- */
function nfmt(n, whole){
  return Math.abs(n).toLocaleString(state.locale||"en-US", {minimumFractionDigits: whole?0:2, maximumFractionDigits:2});
}
function money(n){
  var neg = n<0 ? "-" : "";
  return neg + state.currency + nfmt(n, false);
}
function moneyShort(n){
  // drop the .00 when whole, keep cents otherwise
  var whole = Math.round(n*100)%100 === 0;
  return state.currency + nfmt(n, whole);
}
function $(s){ return document.querySelector(s); }
function vibe(ms){ try{ if(navigator.vibrate) navigator.vibrate(ms); }catch(e){} }

function daysInMonth(y,m){ return new Date(y, m+1, 0).getDate(); }
function nextPayday(){
  var now = new Date(); now.setHours(0,0,0,0);
  var y = now.getFullYear(), m = now.getMonth();
  function paydayInMonth(yy,mm){
    var day = Math.min(state.paydayDay, daysInMonth(yy,mm));
    return new Date(yy, mm, day);
  }
  var p = paydayInMonth(y,m);
  if(p < now){
    m += 1; if(m>11){ m=0; y+=1; }
    p = paydayInMonth(y,m);
  }
  var diff = Math.round((p - now)/86400000);
  return {date:p, diff:diff};
}

/* ---------- Dashboard render ---------- */
var MONTHS = ["January","February","March","April","May","June","July","August","September","October","November","December"];
var DAYS = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
function txThisMonth(type){
  var mk = monthKey();
  return state.tx.filter(function(t){ return t.type===type && monthKey(new Date(t.ts))===mk; })
                 .reduce(function(s,t){ return s+t.amount; },0);
}

function todaySpent(){
  var t = new Date(), y = t.getFullYear(), m = t.getMonth(), d = t.getDate();
  return state.tx.filter(function(x){
    if(x.type!=="expense" || x.billId) return false; // bills aren't daily discretionary spend
    var dd = new Date(x.ts);
    return dd.getFullYear()===y && dd.getMonth()===m && dd.getDate()===d;
  }).reduce(function(s,x){ return s+x.amount; },0);
}

/* Keep a bill's expense transaction in sync with its paid state (current month only) */
function syncBillTx(b){
  var mk = monthKey();
  var existing = state.tx.find(function(t){ return t.billId===b.id && t.billMonth===mk; });
  if(b.paid && (+b.amount>0)){
    if(existing){ existing.amount = +b.amount; existing.category = b.name||"Bill"; }
    else state.tx.push({ id:id(), type:"expense", amount:+b.amount, category:b.name||"Bill", ts:Date.now(), billId:b.id, billMonth:mk });
  } else if(existing){
    state.tx = state.tx.filter(function(t){ return !(t.billId===b.id && t.billMonth===mk); });
  }
}

function renderDaily(){
  var card = $("#dailyCard");
  var budget = +state.dailyBudget || 0;
  if(budget <= 0){
    card.className = "card daily";
    card.innerHTML = '<div class="empty" style="padding:4px 0">Set a daily spending budget · <button class="touch" id="setDaily">Set now</button></div>';
    $("#setDaily").onclick = openSettings;
    return;
  }
  var spent = todaySpent();
  var left = budget - spent;
  var pct = Math.min(100, spent/budget*100);
  var cls = left < 0 ? "over" : (pct >= 80 ? "warn" : "");
  card.className = "card daily " + cls;
  card.innerHTML =
      '<div class="daily-top"><div class="lbl">Today\u2019s budget</div>'
    + '<div class="left num">' + (left<0 ? moneyShort(-left)+" over" : moneyShort(left)+" left") + '</div></div>'
    + '<div class="bar"><div class="fill" style="width:' + pct + '%"></div></div>'
    + '<div class="daily-sub">' + moneyShort(spent) + ' spent of ' + moneyShort(budget) + ' today</div>';
}

function render(){
  var now = new Date();
  $("#dowLbl").textContent = DAYS[now.getDay()];
  $("#dateLbl").textContent = MONTHS[now.getMonth()] + " " + now.getDate() + ", " + now.getFullYear();
  $("#expFig").textContent = moneyShort(txThisMonth("expense"));
  $("#incFig").textContent = moneyShort(txThisMonth("income"));

  // payday
  var pd = nextPayday();
  var bigEl = $("#paydayBig"), metaEl = $("#paydayMeta");
  if(pd.diff===0){ bigEl.textContent = "Payday"; metaEl.innerHTML = "is <b>today</b> 🎉"; }
  else {
    bigEl.textContent = pd.diff + (pd.diff===1?" day":" days");
    metaEl.innerHTML = "till payday · <b>"+MONTHS[pd.date.getMonth()].slice(0,3)+" "+pd.date.getDate()+"</b>";
  }

  renderDaily();
  billsExpanded = false;
  renderBills();
  renderRecent();
  if($("#month").classList.contains("open")) buildMonth();
}

function renderBills(){
  var c = $("#billsCard");
  if(!state.bills.length){
    c.innerHTML = '<div class="empty">No bills yet. <button class="touch" id="addFirstBill">Add your bills</button></div>';
    $("#addFirstBill").onclick = openSettingsTo;
    return;
  }
  var total=0, unpaid=0, unpaidCount=0, html="";
  state.bills.forEach(function(b){
    var amt = +b.amount||0; total += amt;
    if(!b.paid){ unpaid += amt; if(amt>0) unpaidCount++; }
  });
  var allPaid = total>0 && unpaidCount===0;

  // Once everything is paid, shrink to just the total and an "All paid" status.
  if(allPaid && !billsExpanded){
    c.innerHTML =
        '<div class="bills-collapsed touch" id="billsExpand" role="button" tabindex="0" aria-label="Show bills">'
      + '<div class="bf-total"><div class="bf-lbl">Total bills</div><div class="bf-val num">'+moneyShort(total)+'</div></div>'
      + '<div class="allpaid"><svg viewBox="0 0 24 24"><path d="M5 12l5 5L20 6"/></svg>All paid</div>'
      + '<svg class="chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>'
      + '</div>';
    var ex = $("#billsExpand");
    ex.onclick = function(){ billsExpanded = true; renderBills(); };
    ex.onkeydown = function(e){ if(e.key==="Enter"||e.key===" "){ e.preventDefault(); billsExpanded = true; renderBills(); } };
    return;
  }

  state.bills.forEach(function(b){
    html += '<div class="bill '+(b.paid?"paid":"")+' touch" data-bill="'+b.id+'">'
          +   '<div class="check"><svg viewBox="0 0 24 24"><path d="M5 12l5 5L20 6"/></svg></div>'
          +   '<div class="nm">'+esc(b.name)+'</div>'
          +   '<div class="amt num">'+money(+b.amount||0)+'</div>'
          + '</div>';
  });
  html += '<div class="billsfoot">'
        + '<div class="bf-total"><div class="bf-lbl">Total bills</div><div class="bf-val num">'+moneyShort(total)+'</div></div>'
        + '<div class="bf-left'+(allPaid?' done':'')+'"><div class="bf-lbl">Left to pay</div><div class="bf-big num">'+(allPaid?'All paid':moneyShort(unpaid))+'</div></div>'
        + '</div>';
  c.innerHTML = html;
  c.querySelectorAll("[data-bill]").forEach(function(el){
    el.onclick = function(){
      var b = state.bills.find(function(x){return x.id===el.dataset.bill;});
      if(b){ b.paid=!b.paid; syncBillTx(b); vibe(8); billsExpanded=false; save(); render(); }
    };
  });
}

function renderRecent(){
  var wrap=$("#recentWrap"), list=$("#recentList");
  var items = state.tx.slice().sort(function(a,b){return b.ts-a.ts;}).slice(0,6);
  if(!items.length){ wrap.hidden=true; return; }
  wrap.hidden=false;
  list.innerHTML = items.map(function(t){
    var d = new Date(t.ts);
    var ds = MONTHS[d.getMonth()].slice(0,3)+" "+d.getDate();
    var sub = ds + (t.note ? " · "+esc(t.note) : "") + (t.billId ? " · bill" : "");
    return '<div class="tx '+(t.type==="expense"?"exp":"inc")+' touch" data-edit="'+t.id+'" role="button" tabindex="0" aria-label="Edit '+esc(t.category)+'">'
      + '<span class="tag"></span>'
      + '<div class="info"><div class="c">'+esc(t.category)+'</div><div class="d">'+sub+'</div></div>'
      + '<div class="v num">'+(t.type==="expense"?"−":"+")+moneyShort(t.amount)+'</div>'
      + '<button class="del touch" data-del="'+t.id+'" aria-label="Delete"><svg viewBox="0 0 24 24"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg></button>'
      + '</div>';
  }).join("");
  list.querySelectorAll(".tx").forEach(function(row){
    row.onclick = function(){
      var t = state.tx.find(function(x){ return x.id===row.dataset.edit; });
      if(t) openEntry(t.type, t);
    };
    row.onkeydown = function(e){ if(e.key==="Enter"||e.key===" "){ e.preventDefault(); row.click(); } };
  });
  list.querySelectorAll("[data-del]").forEach(function(el){
    el.onclick = function(ev){
      ev.stopPropagation();
      deleteTx(el.dataset.del);
    };
  });
}

/* Delete a transaction with an undo affordance; keeps any linked bill consistent */
function deleteTx(txId){
  var idx = state.tx.findIndex(function(x){ return x.id===txId; });
  if(idx<0) return;
  var removed = state.tx[idx];
  state.tx.splice(idx,1);
  if(removed.billId){
    var b = state.bills.find(function(x){ return x.id===removed.billId; });
    if(b && removed.billMonth===monthKey()) b.paid = false; // unchecking keeps the bill in sync
  }
  vibe(8); save(); render();
  toast("Deleted", "Undo", function(){
    state.tx.push(removed);
    if(removed.billId){
      var bb = state.bills.find(function(x){ return x.id===removed.billId; });
      if(bb && removed.billMonth===monthKey()) bb.paid = true;
    }
    save(); render(); toast("Restored");
  });
}
function esc(s){ return String(s).replace(/[&<>"]/g,function(c){return {"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c];}); }

/* ---------- Month dashboard ---------- */
var monthView = null;     // {y,m} currently shown
var monthSearch = "";
var monthShowAll = false;

function openMonth(){
  var now = new Date();
  monthView = { y:now.getFullYear(), m:now.getMonth() };
  monthSearch = ""; monthShowAll = false;
  buildMonth();
  $("#month").classList.add("open");
}
function closeMonth(){ $("#month").classList.remove("open"); }

function isCurrentMonthView(){
  var now = new Date();
  return monthView.y===now.getFullYear() && monthView.m===now.getMonth();
}
function earliestMonth(){
  if(!state.tx.length) return null;
  var min = state.tx[0].ts;
  state.tx.forEach(function(t){ if(t.ts<min) min=t.ts; });
  var d = new Date(min); return {y:d.getFullYear(), m:d.getMonth()};
}
function monthStep(delta){
  var m = monthView.m + delta, y = monthView.y;
  if(m<0){ m=11; y--; } else if(m>11){ m=0; y++; }
  monthView = {y:y, m:m};
  monthSearch = ""; monthShowAll = false;
  buildMonth();
}
function monthTotals(y,m){
  var mk = y+"-"+String(m+1).padStart(2,"0");
  var income=0, expense=0;
  state.tx.forEach(function(t){
    if(monthKey(new Date(t.ts))!==mk) return;
    if(t.type==="income") income+=t.amount; else expense+=t.amount;
  });
  return {income:income, expense:expense, mk:mk};
}

function buildMonth(){
  var y = monthView.y, m = monthView.m;
  $("#monthTitle").textContent = MONTHS[m] + " " + y;

  // nav button states
  var earliest = earliestMonth();
  var atEarliest = earliest ? (y<earliest.y || (y===earliest.y && m<=earliest.m)) : true;
  $("#monthNext").disabled = isCurrentMonthView();
  $("#monthPrev").disabled = atEarliest;

  var cur = monthTotals(y,m);
  var income = cur.income, expense = cur.expense, net = income - expense;
  var monthTx = state.tx.filter(function(t){ return monthKey(new Date(t.ts))===cur.mk; });

  // previous month, for comparison
  var pm = m-1, py = y; if(pm<0){ pm=11; py--; }
  var prev = monthTotals(py, pm);
  var hasPrev = prev.income>0 || prev.expense>0;

  function deltaPill(label, now, before){
    if(!before) return '';
    var pct = Math.round((now-before)/before*100);
    if(pct===0) return '<span class="pill">'+label+' same as '+MONTHS[pm].slice(0,3)+'</span>';
    var up = pct>0;
    return '<span class="pill '+(up?"up":"down")+'">'+label+' '+(up?"▲":"▼")+' '+Math.abs(pct)+'% vs '+MONTHS[pm].slice(0,3)+'</span>';
  }

  var html = "";
  html += '<div class="card msum">'
        + '<div class="bf-lbl">Net '+(isCurrentMonthView()?"this month":MONTHS[m].slice(0,3)+" "+y)+'</div>'
        + '<div class="mnet num '+(net>=0?"pos":"neg")+'">'+(net<0?"−":"+")+moneyShort(Math.abs(net))+'</div>'
        + '<div class="msum-sub"><span><i class="d in"></i>Income '+moneyShort(income)+'</span>'
        + '<span><i class="d out"></i>Spent '+moneyShort(expense)+'</span></div>'
        + (hasPrev ? '<div class="mcompare">'+deltaPill("Spend", expense, prev.expense)+'</div>' : '')
        + '</div>';

  // Monthly budget progress
  var mb = +state.monthlyBudget || 0;
  if(mb>0){
    var left = mb - expense;
    var pct = Math.min(100, expense/mb*100);
    var cls = left<0 ? "over" : (pct>=80 ? "warn" : "");
    html += '<div class="card daily '+cls+'" style="margin-bottom:24px">'
      + '<div class="daily-top"><div class="lbl">Monthly budget</div>'
      + '<div class="left num">'+(left<0 ? moneyShort(-left)+" over" : moneyShort(left)+" left")+'</div></div>'
      + '<div class="bar"><div class="fill" style="width:'+pct+'%"></div></div>'
      + '<div class="daily-sub">'+moneyShort(expense)+' spent of '+moneyShort(mb)+'</div></div>';
  }

  // Expense breakdown by category
  var byCat = {};
  monthTx.forEach(function(t){ if(t.type==="expense") byCat[t.category]=(byCat[t.category]||0)+t.amount; });
  var cats = Object.keys(byCat).map(function(k){ return {name:k, amt:byCat[k]}; })
                  .sort(function(a,b){ return b.amt-a.amt; });
  if(cats.length){
    var palette = ["#E5484D","#F2820D","#E8B30A","#5B8DEF","#8B5CF6","#EC4899","#14B8A6","#6B7280"];
    var shown = cats;
    if(cats.length > palette.length){
      var head = cats.slice(0, palette.length-1);
      var restAmt = cats.slice(palette.length-1).reduce(function(s,c){ return s+c.amt; },0);
      head.push({ name:"Other", amt:restAmt });
      shown = head;
    }
    var segs = shown.map(function(c,i){
      var w = expense ? c.amt/expense*100 : 0;
      return '<div class="seg" style="width:'+w+'%; background:'+palette[i]+'"></div>';
    }).join("");
    var legend = shown.map(function(c,i){
      var pct2 = expense ? Math.round(c.amt/expense*100) : 0;
      return '<div class="leg"><span class="sw" style="background:'+palette[i]+'"></span>'
        + '<span class="ln">'+esc(c.name)+'</span>'
        + '<span class="lv num">'+moneyShort(c.amt)+' · '+pct2+'%</span></div>';
    }).join("");
    html += '<div class="msec"><div class="bf-lbl">Where it went</div>'
      + '<div class="card" style="padding:16px 16px 6px">'
      + '<div class="stackbar">'+segs+'</div>'
      + '<div class="legend">'+legend+'</div>'
      + '<div class="stacktotal"><span>Total spent</span><span class="num">'+moneyShort(expense)+'</span></div>'
      + '</div></div>';
  }

  // Transactions: search + grouped list
  if(monthTx.length){
    html += '<div class="msec"><div class="bf-lbl">Transactions · '+monthTx.length+'</div>'
      + '<div class="msearch"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>'
      + '<input type="text" id="monthSearchInput" placeholder="Search category or note" value="'+esc(monthSearch)+'"></div>'
      + '<div id="monthTxList"></div></div>';
  } else {
    html += '<div class="empty" style="margin-top:24px">No activity '+(isCurrentMonthView()?"yet this month":"in "+MONTHS[m].slice(0,3))+'. Tap Income or Expense to start.</div>';
  }

  var body = $("#monthBody");
  body.innerHTML = html;

  // wire nav
  $("#monthPrev").onclick = function(){ if(!this.disabled) monthStep(-1); };
  $("#monthNext").onclick = function(){ if(!this.disabled) monthStep(1); };

  if(monthTx.length){
    var search = $("#monthSearchInput");
    search.oninput = function(){ monthSearch = this.value; monthShowAll = false; renderMonthTxList(monthTx); };
    renderMonthTxList(monthTx);
  }
}

function renderMonthTxList(monthTx){
  var listEl = $("#monthTxList");
  if(!listEl) return;
  var q = monthSearch.trim().toLowerCase();
  var filtered = monthTx.filter(function(t){
    if(!q) return true;
    return (t.category||"").toLowerCase().indexOf(q)>=0 || (t.note||"").toLowerCase().indexOf(q)>=0;
  }).sort(function(a,b){ return b.ts-a.ts; });

  if(!filtered.length){
    listEl.innerHTML = '<div class="empty" style="padding:18px 0">No matches for "'+esc(monthSearch.trim())+'".</div>';
    return;
  }

  var CAP = 50;
  var capped = (!monthShowAll && filtered.length>CAP) ? filtered.slice(0,CAP) : filtered;

  // group by day
  var html = "", curKey = null;
  capped.forEach(function(t){
    var d = new Date(t.ts);
    var key = d.getFullYear()+"-"+d.getMonth()+"-"+d.getDate();
    if(key!==curKey){
      curKey = key;
      // day total (across all of that day's filtered tx)
      var dayTx = filtered.filter(function(x){ var xd=new Date(x.ts); return xd.getFullYear()+"-"+xd.getMonth()+"-"+xd.getDate()===key; });
      var dayExp = dayTx.reduce(function(s,x){ return s + (x.type==="expense"?x.amount:0); },0);
      var hdr = DAYS[d.getDay()].slice(0,3)+", "+MONTHS[d.getMonth()].slice(0,3)+" "+d.getDate();
      html += '<div class="dayhdr"><span>'+hdr+'</span>'+(dayExp>0?'<span class="dsum num">'+moneyShort(dayExp)+' spent</span>':'')+'</div>';
    }
    var sub = (t.note ? esc(t.note) : "") + (t.billId ? (t.note?" · ":"")+"bill" : "");
    html += '<div class="tx '+(t.type==="expense"?"exp":"inc")+' touch" data-edit="'+t.id+'" role="button" tabindex="0" aria-label="Edit '+esc(t.category)+'">'
      + '<span class="tag"></span>'
      + '<div class="info"><div class="c">'+esc(t.category)+'</div>'+(sub?'<div class="d">'+sub+'</div>':'')+'</div>'
      + '<div class="v num">'+(t.type==="expense"?"−":"+")+moneyShort(t.amount)+'</div>'
      + '</div>';
  });

  if(!monthShowAll && filtered.length>CAP){
    html += '<button class="showmore touch" id="monthShowMore">Show all '+filtered.length+' transactions</button>';
  }

  listEl.innerHTML = html;
  listEl.querySelectorAll(".tx").forEach(function(row){
    row.onclick = function(){
      var t = state.tx.find(function(x){ return x.id===row.dataset.edit; });
      if(t) openEntry(t.type, t);
    };
    row.onkeydown = function(e){ if(e.key==="Enter"||e.key===" "){ e.preventDefault(); row.click(); } };
  });
  var more = $("#monthShowMore");
  if(more) more.onclick = function(){ monthShowAll = true; renderMonthTxList(monthTx); };
}

/* ---------- Entry sheet ---------- */
function toDateStr(d){ return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0"); }
function tsFromDateStr(s){
  if(s === toDateStr(new Date())) return Date.now();   // today keeps real time for natural ordering
  var p = s.split("-");
  return new Date(+p[0], +p[1]-1, +p[2], 12, 0, 0).getTime();
}
var entry = { type:"expense", amount:"0", cat:null, editId:null, date:null, note:"" };
function openEntry(type, editTx){
  entry.type = type;
  entry.editId = editTx ? editTx.id : null;
  entry.amount = editTx ? String(editTx.amount) : "0";
  entry.cat = editTx ? editTx.category : null;
  entry.date = editTx ? toDateStr(new Date(editTx.ts)) : toDateStr(new Date());
  entry.note = editTx ? (editTx.note||"") : "";
  var sheet = $("#entry");
  sheet.classList.remove("expense","income");
  sheet.classList.add(type);
  $("#entryTitle").textContent = (editTx ? "Edit " : "") + (type==="expense" ? "Expense" : "Income");
  $("#entryDelete").style.display = editTx ? "grid" : "none";
  $("#entryCur").textContent = state.currency;
  var dateInp = $("#entryDate");
  dateInp.max = toDateStr(new Date());
  dateInp.value = entry.date;
  $("#entryNote").value = entry.note;
  renderChips();
  updateAmount();
  sheet.classList.add("open");
}
function closeEntry(){ $("#entry").classList.remove("open"); }

function renderChips(){
  var box = $("#entryChips");
  var list = entry.type==="expense" ? state.categories : state.sources;
  if(!entry.cat && list.length) entry.cat = list[0]; // preselect first → fewer taps
  var html = list.map(function(c){
    return '<button class="chip touch '+(c===entry.cat?"sel":"")+'" data-cat="'+esc(c)+'">'+esc(c)+'</button>';
  }).join("");
  html += '<button class="chip add touch" id="addCat">+ New</button>';
  box.innerHTML = html;
  box.querySelectorAll("[data-cat]").forEach(function(el){
    el.onclick = function(){ entry.cat = el.dataset.cat; vibe(6); renderChips(); updateAmount(); };
  });
  $("#addCat").onclick = function(){
    var name = prompt(entry.type==="expense" ? "New expense category" : "New income source");
    if(name && name.trim()){
      name = name.trim();
      var arr = entry.type==="expense" ? state.categories : state.sources;
      if(arr.indexOf(name)===-1){ arr.push(name); save(); }
      entry.cat = name; renderChips(); updateAmount();
    }
  };
}

function pressKey(k){
  vibe(5);
  if(k==="bsp"){ entry.amount = entry.amount.length>1 ? entry.amount.slice(0,-1) : "0"; }
  else if(k==="."){ if(entry.amount.indexOf(".")===-1) entry.amount += "."; }
  else {
    var parts = entry.amount.split(".");
    if(parts[1] && parts[1].length>=2) return;      // max 2 decimals
    if(entry.amount==="0" && k!=="."){ entry.amount = k; }
    else { if(entry.amount.replace(".","").length>=12) return; entry.amount += k; }
  }
  updateAmount();
}
function updateAmount(){
  var val = $("#entryVal");
  var n = parseFloat(entry.amount)||0;
  // show what's typed (preserve a trailing dot while typing)
  var disp = entry.amount;
  if(disp.indexOf(".")===-1) disp = Number(entry.amount).toLocaleString(state.locale||"en-US");
  else {
    var p = entry.amount.split(".");
    disp = Number(p[0]).toLocaleString(state.locale||"en-US") + "." + p[1];
  }
  val.textContent = disp;
  val.classList.toggle("zero", n===0);
  fitAmount(disp);
  $("#entrySave").disabled = !(n>0 && entry.cat);
}
function fitAmount(disp){
  var len = (state.currency + disp).length;
  var size = len<=7 ? 54 : len<=8 ? 47 : len<=9 ? 42 : len<=11 ? 36 : len<=13 ? 31 : 27;
  $("#amountBox").style.fontSize = size + "px";
}
function saveEntry(){
  var n = parseFloat(entry.amount)||0;
  if(!(n>0) || !entry.cat) return;
  var note = (entry.note||"").trim();
  if(entry.editId){
    var t = state.tx.find(function(x){ return x.id===entry.editId; });
    if(t){
      t.amount = Math.round(n*100)/100;
      t.category = entry.cat;
      if(note) t.note = note; else delete t.note;
      if(toDateStr(new Date(t.ts)) !== entry.date) t.ts = tsFromDateStr(entry.date);
    }
  } else {
    var rec = { id:id(), type:entry.type, amount:Math.round(n*100)/100, category:entry.cat, ts:tsFromDateStr(entry.date) };
    if(note) rec.note = note;
    state.tx.push(rec);
  }
  save(); vibe([10,30,10]);
  var wasEdit = !!entry.editId;
  closeEntry();
  render();
  toast(wasEdit ? "Updated" : ((entry.type==="expense"?"Expense":"Income")+" added · "+money(n)));
}

/* ---------- Toast ---------- */
var toastTimer;
function toast(msg, actionLabel, actionFn){
  var t=$("#toast");
  if(actionLabel && actionFn){
    t.classList.add("has-action");
    t.innerHTML = '<span>'+esc(msg)+'</span><button class="undo touch">'+esc(actionLabel)+'</button>';
    t.querySelector(".undo").onclick = function(){ clearTimeout(toastTimer); t.classList.remove("show"); actionFn(); };
  } else {
    t.classList.remove("has-action");
    t.textContent = msg;
  }
  t.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer=setTimeout(function(){ t.classList.remove("show"); }, actionLabel ? 4500 : 1700);
}

/* ---------- Settings ---------- */
function openSettings(){ buildSettings(); $("#settings").classList.add("open"); }
function openSettingsTo(){ openSettings(); }
function closeSettings(){ $("#settings").classList.remove("open"); render(); }

function buildSettings(){
  $("#setPayday").value = state.paydayDay;
  $("#setDailyInput").value = state.dailyBudget || "";
  $("#setMonthlyInput").value = state.monthlyBudget || "";
  $("#setCur").value = state.currency;
  $("#setLocale").value = state.locale || "en-US";
  buildList("#billsGroup","Monthly bills", state.bills, true, null, "These repeat automatically every month. Checking one logs it as an expense for the month; checkmarks reset on the 1st.");
  buildList("#catGroup","Expense categories", state.categories, false, "categories");
  buildList("#srcGroup","Income sources", state.sources, false, "sources");
}

function buildList(sel, heading, arr, isBills, plainKey, note){
  var g = $(sel);
  var html = '<h3>'+heading+'</h3>' + (note ? '<div class="setnote">'+note+'</div>' : '');
  if(isBills){
    arr.forEach(function(b){
      html += '<div class="listrow" data-bid="'+b.id+'">'
        + '<div class="nm"><input type="text" value="'+esc(b.name)+'" data-f="name" placeholder="Bill name"></div>'
        + '<div class="amt"><input type="number" inputmode="decimal" value="'+(b.amount||"")+'" data-f="amount" placeholder="0"></div>'
        + '<button class="rm touch" data-rm="'+b.id+'" aria-label="Remove"><svg viewBox="0 0 24 24"><path d="M5 12h14"/></svg></button>'
        + '</div>';
    });
    html += '<div class="addrow touch" id="addBillRow"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>Add a bill</div>';
  } else {
    arr.forEach(function(name,i){
      html += '<div class="listrow" data-idx="'+i+'">'
        + '<div class="nm"><input type="text" value="'+esc(name)+'" data-plain="'+plainKey+'" data-i="'+i+'"></div>'
        + '<button class="rm touch" data-rmplain="'+plainKey+'" data-i="'+i+'" aria-label="Remove"><svg viewBox="0 0 24 24"><path d="M5 12h14"/></svg></button>'
        + '</div>';
    });
    html += '<div class="addrow touch" data-addplain="'+plainKey+'"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>Add '+(plainKey==="categories"?"category":"source")+'</div>';
  }
  g.innerHTML = html;

  // bind bills
  g.querySelectorAll("[data-bid]").forEach(function(row){
    var b = state.bills.find(function(x){return x.id===row.dataset.bid;});
    row.querySelectorAll("input").forEach(function(inp){
      inp.onchange = function(){
        var mk = monthKey();
        if(inp.dataset.f==="name"){
          var oldName = b.name;
          b.name = inp.value.trim()||"Bill";
          // keep this month's logged payment labelled correctly
          state.tx.forEach(function(x){ if(x.billId===b.id && x.billMonth===mk) x.category = b.name; });
        } else {
          b.amount = parseFloat(inp.value)||0;
        }
        syncBillTx(b); // reconcile the logged expense with new name/amount/paid state
        save();
      };
    });
  });
  var addBill = g.querySelector("#addBillRow");
  if(addBill) addBill.onclick = function(){ state.bills.push({id:id(),name:"",amount:0,paid:false}); save(); buildSettings(); };

  // bind plain lists
  g.querySelectorAll("[data-plain]").forEach(function(inp){
    inp.onchange = function(){
      var key = inp.dataset.plain;
      var arrx = state[key];
      var i = +inp.dataset.i;
      var oldName = arrx[i];
      var v = inp.value.trim();
      if(v && v!==oldName){
        arrx[i] = v;
        // propagate the rename to existing transactions of the matching type
        var ty = key==="categories" ? "expense" : "income";
        state.tx.forEach(function(x){ if(x.type===ty && x.category===oldName) x.category = v; });
        save();
      }
    };
  });
  g.querySelectorAll("[data-addplain]").forEach(function(el){
    el.onclick = function(){ state[el.dataset.addplain].push("New"); save(); buildSettings(); };
  });
  g.querySelectorAll("[data-rm]").forEach(function(el){
    el.onclick = function(){ state.bills = state.bills.filter(function(x){return x.id!==el.dataset.rm;}); save(); buildSettings(); };
  });
  g.querySelectorAll("[data-rmplain]").forEach(function(el){
    el.onclick = function(){ state[el.dataset.rmplain].splice(+el.dataset.i,1); save(); buildSettings(); };
  });
}

/* ---------- Wire up ---------- */
function init(){
  load();
  render();

  $("#addExpense").onclick = function(){ openEntry("expense"); };
  $("#addIncome").onclick  = function(){ openEntry("income"); };
  $("#entryClose").onclick = closeEntry;
  $("#entrySave").onclick  = saveEntry;
  $("#entryDelete").onclick = function(){
    var delId = entry.editId;
    closeEntry();
    if(delId) deleteTx(delId);
  };
  $("#openSettings").onclick = openSettings;
  $("#dateBtn").onclick = openMonth;
  $("#monthClose").onclick = closeMonth;
  $("#editBills").onclick = openSettings;
  $("#settingsClose").onclick = closeSettings;

  document.querySelectorAll("#entry .key").forEach(function(k){
    k.onclick = function(){ pressKey(k.dataset.k); };
  });
  $("#entryDate").onchange = function(){ entry.date = this.value || toDateStr(new Date()); };
  $("#entryNote").oninput = function(){ entry.note = this.value; };

  $("#setPayday").onchange = function(){
    var v = Math.min(31, Math.max(1, parseInt(this.value)||1));
    this.value = v; state.paydayDay = v; save();
  };
  $("#setDailyInput").onchange = function(){
    state.dailyBudget = Math.max(0, parseFloat(this.value)||0); save();
  };
  $("#setMonthlyInput").onchange = function(){
    state.monthlyBudget = Math.max(0, parseFloat(this.value)||0); save();
  };
  $("#setCur").onchange = function(){
    state.currency = (this.value.trim()||"S$").slice(0,4); save();
  };
  $("#setLocale").onchange = function(){
    state.locale = this.value || "en-US"; save();
  };

  // backup / restore / erase
  $("#exportBtn").onclick = function(){
    var data = JSON.stringify(state, null, 2);
    var name = "money-backup-" + monthKey() + ".json";
    if(Fs){
      // write to the app cache, then open the share sheet so you can save it
      // to Files, Drive, etc. — i.e. real, durable phone storage.
      Fs.writeFile({ path:name, data:data, directory:"CACHE", encoding:"utf8" }).then(function(res){
        if(ShareP){
          return ShareP.share({ title:"Money backup", url:res.uri, dialogTitle:"Save your Money backup" })
            .catch(function(){ /* user dismissed the share sheet */ });
        }
        toast("Backup saved");
      }).catch(function(){
        // last resort: keep a durable copy in app storage
        Fs.writeFile({ path:name, data:data, directory:"DATA", encoding:"utf8" })
          .then(function(){ toast("Backup saved on device"); })
          .catch(function(){ toast("Couldn't save backup"); });
      });
    } else {
      var blob = new Blob([data], {type:"application/json"});
      var a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = name;
      document.body.appendChild(a); a.click(); a.remove();
      toast("Backup downloaded");
    }
  };
  $("#importBtn").onclick = function(){ $("#importFile").click(); };
  $("#importFile").onchange = function(e){
    var f = e.target.files[0]; if(!f) return;
    var r = new FileReader();
    r.onload = function(){
      try{
        var data = JSON.parse(r.result);
        if(data && Array.isArray(data.tx)){
          state = applyDefaults(data);   // fill any missing fields so nothing breaks
          state.onboarded = true;
          save(); buildSettings(); render(); toast("Data restored");
        } else toast("That file doesn't look right");
      }catch(err){ toast("Couldn't read that file"); }
    };
    r.readAsText(f);
    e.target.value = "";
  };
  $("#clearBtn").onclick = function(){
    if(confirm("Erase everything and start fresh? This can't be undone.")){
      state = defaults(); state.onboarded = true; save(); buildSettings(); render(); toast("All data erased");
    }
  };

  // hardware/keyboard niceties for desktop testing
  document.addEventListener("keydown", function(e){
    if(!$("#entry").classList.contains("open")) return;
    var tag = (e.target.tagName||"").toLowerCase();
    if(tag==="input") return; // don't hijack typing in the date/note fields
    if(/[0-9]/.test(e.key)) pressKey(e.key);
    else if(e.key===".") pressKey(".");
    else if(e.key==="Backspace") pressKey("bsp");
    else if(e.key==="Enter") saveEntry();
    else if(e.key==="Escape") closeEntry();
  });

  // keep dashboard fresh if the day rolls over while the app stays open
  document.addEventListener("visibilitychange", function(){ if(!document.hidden) render(); });
  window.addEventListener("focus", function(){ render(); });

  // first-run onboarding
  function finishOnboarding(){
    state.currency = ($("#obCur").value.trim()||"S$").slice(0,4);
    state.paydayDay = Math.min(31, Math.max(1, parseInt($("#obPayday").value)||25));
    state.dailyBudget = Math.max(0, parseFloat($("#obDaily").value)||0);
    state.onboarded = true;
    save(); $("#onboard").classList.remove("open"); render();
  }
  $("#obStart").onclick = finishOnboarding;
  $("#obSkip").onclick = function(){ state.onboarded = true; save(); $("#onboard").classList.remove("open"); };
  if(!state.onboarded){ $("#onboard").classList.add("open"); }
}

/* Resolve plugins, hydrate persisted data, then start the app */
function boot(){
  Prefs  = getPlugin("Preferences");
  Fs     = getPlugin("Filesystem");
  ShareP = getPlugin("Share");
  if(Prefs){
    Prefs.get({ key:KEY }).then(function(res){
      var val = res ? res.value : null;
      if(val === null || val === undefined){
        // one-time migration of anything left in the WebView's localStorage
        var legacy = null; try { legacy = window.localStorage.getItem(KEY); } catch(e){}
        if(legacy != null){ val = legacy; Prefs.set({ key:KEY, value:legacy }).catch(function(){}); }
      }
      mem = (val == null ? null : val);
      init();
    }).catch(function(){
      try { mem = window.localStorage.getItem(KEY); } catch(e){ mem = null; }
      init();
    });
  } else {
    try { mem = window.localStorage.getItem(KEY); } catch(e){ mem = null; }
    init();
  }
}
boot();
</script>
</body>
</html>
